<?xml version="1.0" encoding="utf-8"?>
<!--
  WiX v4 manifest for the Collaborative Layout Designer MSI.

  Minimal proper-installer shape:
   - Installs everything under  %ProgramFiles%\Collaborative Layout Designer\
   - Creates a Start menu shortcut
   - Registers a shared "App Paths" entry so `collaborative-layout-designer`
     on cmd.exe finds the binary without full-path PATH surgery
   - No per-user state, no persistent file associations (the .bbm MIME
     lives in the .desktop file on Linux; Windows users double-click
     from Explorer and the app opens them via argv[1])

  The exe + Qt + parts library all live inside the staging tree
  assembled by the workflow BEFORE candle/light run; this wxs file
  uses a HEAT-generated component group (generated during the build
  step) to include everything under that tree.

  No code-signing — per project decision to not require an EV cert
  or Apple Developer ID. End users will see an "unknown publisher"
  SmartScreen warning the first time they install; "More info → Run
  anyway" proceeds normally. Same tradeoff as the macOS DMG.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="Collaborative Layout Designer"
           Manufacturer="Collaborative Layout Designer contributors"
           Version="0.4.1.0"
           UpgradeCode="7d5c9ad0-1b8a-4c2f-8b1f-7e6c1a3b5f4d"
           Scope="perMachine"
           Compressed="yes">

    <SummaryInformation Description="Cross-platform maintainer fork of BlueBrick" />

    <MajorUpgrade DowngradeErrorMessage="A newer version is already installed." />

    <!-- Embed the .cab into the MSI so a single file is enough to install. -->
    <MediaTemplate EmbedCab="yes" />

    <!-- Standard "Application" shortcut in the Start menu. -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="Collaborative Layout Designer" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Collaborative Layout Designer" />
    </StandardDirectory>

    <!-- Main app component: the exe + a Start menu shortcut.
         The rest of the payload (Qt DLLs, parts library) is pulled
         in by the HEAT-generated Harvested.wxs component group. -->
    <ComponentGroup Id="MainAppComponents" Directory="INSTALLFOLDER">
      <Component Id="MainExe" Guid="*">
        <File Id="CollaborativeLayoutDesignerExe"
              Source="staging\collaborative-layout-designer.exe"
              KeyPath="yes">
          <Shortcut Id="AppShortcut"
                    Directory="ApplicationProgramsFolder"
                    Name="Collaborative Layout Designer"
                    WorkingDirectory="INSTALLFOLDER"
                    Advertise="yes" />
        </File>
        <RegistryValue Root="HKLM"
                       Key="SOFTWARE\Microsoft\Windows\CurrentVersion\App Paths\collaborative-layout-designer.exe"
                       Value="[INSTALLFOLDER]collaborative-layout-designer.exe"
                       Type="string" />
      </Component>
      <Component Id="StartMenuDirComponent"
                 Directory="ApplicationProgramsFolder"
                 Guid="b3d2e4f1-5a6c-4a8e-91f1-c0a7d4e8b2a3">
        <RemoveFolder Id="CleanupStartMenuFolder" On="uninstall" />
        <RegistryValue Root="HKCU"
                       Key="SOFTWARE\CollaborativeLayoutDesigner"
                       Name="installed"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <Feature Id="MainFeature" Title="Collaborative Layout Designer" Level="1">
      <ComponentGroupRef Id="MainAppComponents" />
      <!-- `HarvestedComponents` is the name heat.exe emits for the staged
           support files (Qt runtime, parts library, translations). -->
      <ComponentGroupRef Id="HarvestedComponents" />
    </Feature>

  </Package>
</Wix>
